# 日志级别：INFO / DEBUG（DEBUG 可打印 image_uri 为 NULL 的原因）
# LOG_LEVEL=INFO

# ── 链配置 ────────────────────────────────────────────────────
# 链名称（写入数据库的标识符）
CHAIN_NAME=base

# RPC 节点地址（支持 Chainstack、Alchemy、QuickNode 等）
RPC_URL=https://mainnet.base.org

# 扫描终点（最旧区块，0 = 一直扫到创世块）
START_BLOCK=0

# 扫描起点（最新区块，0 = 自动取链上当前最新区块）
END_BLOCK=0

# 每次 eth_getLogs 请求的区块跨度（免费节点建议 500~2000）
BLOCK_BATCH_SIZE=500

# 每次 RPC 请求后的等待秒数（防止触发频率限制）
REQUEST_DELAY=0.2

# 并发数：Alchemy 批量请求并发数 / RPC（tokenURI 链上回退）并发数
CONCURRENT_ALCHEMY=10
CONCURRENT_RPC=10

# log_scanner 滑动窗口宽度：同时在途的 eth_getLogs 批次数（建议 2~5）
SCAN_WINDOW=3

# Alchemy / metadata 请求超时（秒）
METADATA_TIMEOUT=10
METADATA_CONNECT_TIMEOUT=15

# ── Alchemy NFT API ───────────────────────────────────────────
# Alchemy API Key（在 https://dashboard.alchemy.com 申请）
ALCHEMY_API_KEY=your_alchemy_api_key
ETHERSCAN_API_KEY=

# Alchemy 网络子域名（与链对应）
# 常用值：polygon-mainnet / eth-mainnet / base-mainnet / arb-mainnet / opt-mainnet
ALCHEMY_NETWORK=polygon-mainnet

# 每次批量请求携带的 token 数量（Alchemy 上限 100）
ALCHEMY_BATCH_SIZE=100

# ── metadata_fetcher 专用 ────────────────────────────────────────
# 无待处理记录时等待的秒数
FETCH_IDLE_WAIT=30

# metadata_fetcher worker 进程数（1 = 单进程；建议从 2 开始压测）
FETCHER_WORKERS=2

# 每个 worker 单次从临时表认领的记录数
FETCH_CLAIM_BATCH_SIZE=2000

# worker 异常退出后，认领记录重新可被其他 worker 接管的超时时间（秒）
CLAIM_RETRY_AFTER_SECONDS=600

# ── metadata_backfill 专用 ────────────────────────────────────────
# 回填链列表（逗号分隔）
METADATA_BACKFILL_CHAINS=ethereum,base,polygon

# 回填模式：alchemy 或 token_uri（二选一）
METADATA_BACKFILL_MODE=alchemy

# 每轮从主表读取的缺失 metadata 记录数
METADATA_BACKFILL_SEGMENT_SIZE=1000

# 单次网络批量请求携带的 token 数
METADATA_BACKFILL_BATCH_SIZE=100

# 网络并发数（Alchemy 批次数或 token_uri HTTP 并发）
METADATA_BACKFILL_WORKERS=5

# 无待回填记录时的等待秒数
METADATA_BACKFILL_IDLE_WAIT=600

# ── 合约黑名单（DeFi 等协议 NFT 不采集）────────────────────────
# 逗号分隔的地址
DEFI_BLACKLIST=0xabc...,0xdef...

# ── PostgreSQL 配置 ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nft_data
DB_USER=postgres
DB_PASS=your_password
