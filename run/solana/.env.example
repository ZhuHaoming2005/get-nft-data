# ── 链配置 ────────────────────────────────────────────────────
# 链名称（写入数据库的标识符）
CHAIN_NAME=solana

# ── GPA 扫描参数（tx_scanner.py 当前模式：getProgramAccountsV2）────────────
# 每页拉取的账户数（1~10000）
# 建议 1000：响应速度快、内存占用稳定
# 节点稳定时可调至 2000~5000 进一步减少请求次数
GPA_PAGE_SIZE=1000

# 增量模式起始 Slot（0 = 全量扫描或使用 DB 自动进度）
# 设置为 >0 时可从该 slot 的 changedSinceSlot 开始；若 DB 已有更靠后的进度，DB 优先
# 同 slot 中断后会从 DB paginationKey 续扫；扫描完成后写入最新 Slot 供后续自动增量使用
GPA_SINCE_SLOT=0

# ── metadata_fetcher 并发参数 ─────────────────────────────────────────────────
# 同时在途的 getAssetBatch 请求数
# 5 并发 × 1000 mint/请求 = 每轮处理 5000 条（免费层建议 3~5，付费层可调至 10+）
CONCURRENT_HELIUS=10

# metadata 请求超时（秒）
METADATA_TIMEOUT=30
METADATA_CONNECT_TIMEOUT=30

# ── Helius DAS API ────────────────────────────────────────────
# Helius API Key（在 https://dashboard.helius.dev 申请，免费层即可）
# 用于 getAssetBatch，一次请求最多获取 1000 个 NFT 的完整元数据
# Helius DAS API 文档：https://docs.helius.dev/compression-and-das-api/digital-asset-standard-das-api
HELIUS_API_KEY=<YOUR_HELIUS_API_KEY>

# 单次 getAssetBatch 携带的 mint 数量（Helius 官方上限 1000）
HELIUS_BATCH_SIZE=1000

# ── metadata_fetcher 专用 ────────────────────────────────────────
# 无待处理记录时等待的秒数
FETCH_IDLE_WAIT=600

# metadata_fetcher worker 进程数；>1 时通过 claimed_at/claimed_by + SKIP LOCKED 安全并行
FETCHER_WORKERS=3

# 单个 worker 每次从 temp_solana 原子认领的记录数
FETCH_CLAIM_BATCH_SIZE=5000

# 认领超时回收秒数；应大于单批最慢 metadata 获取 + 写库耗时
CLAIM_RETRY_AFTER_SECONDS=1800

# worker 启动错峰秒数；多 worker 且 API 容易冷启动限流时可设为 1~5
WORKER_STARTUP_DELAY_SECONDS=5

# 停止信号后的 worker 收尾宽限秒数
WORKER_SHUTDOWN_GRACE_SECONDS=60

# 兼容 Base 链的请求启动错峰变量；Solana worker 默认也会读取它作为启动错峰默认值
REQUEST_STARTUP_STAGGER_SECONDS=5

# 主表批量写入分页大小，避免单条 INSERT SQL 过大
DB_INSERT_PAGE_SIZE=1000

# ── PostgreSQL 配置 ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nft_data
DB_USER=user1
DB_PASS=_JC!y7XWygm$94f
