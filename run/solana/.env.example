# ── 链配置 ────────────────────────────────────────────────────
# 链名称（写入数据库的标识符）
CHAIN_NAME=solana

# Solana RPC 节点地址（支持 Alchemy、QuickNode、Helius、官方公共节点等）
# 官方公共节点（有限速）: https://api.mainnet-beta.solana.com
# Alchemy:    https://solana-mainnet.g.alchemy.com/v2/<YOUR_API_KEY>
# Helius:     https://mainnet.helius-rpc.com/?api-key=<YOUR_API_KEY>
RPC_URL=https://mainnet.helius-rpc.com/?api-key=1b7f1a72-bfb7-44de-ad19-eb441936fa8b

# ── GPA 扫描参数（tx_scanner.py 当前模式：getProgramAccountsV2）────────────
# 每页拉取的账户数（1~10000）
# 建议 1000：响应速度快、内存占用稳定
# 节点稳定时可调至 2000~5000 进一步减少请求次数
GPA_PAGE_SIZE=1000

# 增量模式起始 Slot（0 = 全量扫描）
# 首次运行保持 0，全量扫完后脚本会自动将当时的最新 Slot 存入 DB
# 下次运行自动读取 DB 值进入增量模式，此处无需手动修改
GPA_SINCE_SLOT=0

# ── metadata_fetcher 并发参数 ─────────────────────────────────────────────────
# 同时在途的 getAssetBatch 请求数
# 5 并发 × 1000 mint/请求 = 每轮处理 5000 条（免费层建议 3~5，付费层可调至 10+）
CONCURRENT_HELIUS=10

# 同时在途的图片 HTTP 请求数（链上路径中 metadata JSON + image 拉取）
CONCURRENT_IMAGE=50

# metadata 请求超时（秒）
METADATA_TIMEOUT=30
METADATA_CONNECT_TIMEOUT=30

# ── Helius DAS API ────────────────────────────────────────────
# Helius API Key（在 https://dashboard.helius.dev 申请，免费层即可）
# 用于 getAssetBatch，一次请求最多获取 1000 个 NFT 的完整元数据
# Helius DAS API 文档：https://docs.helius.dev/compression-and-das-api/digital-asset-standard-das-api
HELIUS_API_KEY=1b7f1a72-bfb7-44de-ad19-eb441936fa8b

# 单次 getAssetBatch 携带的 mint 数量（Helius 官方上限 1000）
HELIUS_BATCH_SIZE=1000

# ── metadata_fetcher 专用 ────────────────────────────────────────
# 无待处理记录时等待的秒数
FETCH_IDLE_WAIT=600

# ── PostgreSQL 配置 ────────────────────────────────────────────
DB_HOST=pgm-2zevls2414y7mw6d8o.pg.rds.aliyuncs.com
DB_PORT=5432
DB_NAME=nft_data
DB_USER=user1
DB_PASS=_JC!y7XWygm$94f
