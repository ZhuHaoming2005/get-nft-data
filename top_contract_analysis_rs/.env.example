# This project does not auto-load .env files.
# PostgreSQL connection for `export-snapshot` is configured in src/constants.rs.
# Load these variables into your shell only when you want to interpolate CLI args.

# API credentials for shell interpolation in `analyze` / `batch`
ALCHEMY_API_KEY=
ALCHEMY_NETWORK=eth-mainnet
ETHERSCAN_API_KEY=
OPENSEA_API_KEY=

# Optional local paths you may reuse in commands
FEATURE_PARQUET=.\data\ethereum_snapshot.parquet
FEATURE_DB=.\data\feature_store.duckdb
SIGNAL_CACHE_DB=.\data\signal_cache.duckdb
OUTPUT_DIR=.\result
